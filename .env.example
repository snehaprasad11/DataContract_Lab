# Copy this file to .env and fill in your own values. Never commit the real .env.
# Locally, these come from .env. In a Streamlit Cloud deployment, set the same keys
# in the app's Secrets box instead (st.secrets takes priority over these env vars).

# --- Database (local MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=datacontract_lab

# --- Database TLS ---
# Leave false for local MySQL. Set true for hosted providers that require TLS
# (e.g. TiDB Cloud Serverless). When true, the app verifies the server using
# certifi's CA bundle — no certificate file to manage.
DB_SSL=false

# --- Optional local LLM ---
# The "Explain with local LLM" button calls a local Ollama at localhost:11434.
# Keep true locally. Set false on a hosted deployment, where a local Ollama is
# unreachable, so the button is hidden instead of always failing.
ENABLE_OLLAMA=true

# --- Display timezone ---
# Scan-history timestamps are always stored in UTC; this only controls how they're
# displayed. Use any IANA timezone name, e.g. Asia/Kolkata, America/New_York, Europe/London.
# Defaults to UTC if unset or invalid.
APP_TIMEZONE=UTC
